PageContainer.BackgroundTransparency = 1

local Pages = {}
local function AddTab(name)
    local P = Instance.new("ScrollingFrame", PageContainer)
    P.Size = UDim2.new(1, 0, 1, 0)
    P.BackgroundTransparency = 1
    P.Visible = false
    P.ScrollBarThickness = 0
    Instance.new("UIListLayout", P).Padding = UDim.new(0, 8)
    
    local TabBtn = Instance.new("TextButton", Sidebar)
    TabBtn.Size = UDim2.new(1, 0, 0, 36)
    TabBtn.Text = "  " .. name
    TabBtn.TextColor3 = Color3.fromRGB(160, 160, 160)
    TabBtn.Font = Enum.Font.GothamMedium
    TabBtn.TextXAlignment = Enum.TextXAlignment.Left
    TabBtn.BackgroundTransparency = 1
    
    TabBtn.MouseButton1Click:Connect(function()
        for _, v in pairs(Pages) do v.Visible = false end
        P.Visible = true
        for _, t in pairs(Sidebar:GetChildren()) do
            if t:IsA("TextButton") then t.TextColor3 = Color3.fromRGB(160, 160, 160) end
        end
        TabBtn.TextColor3 = Color3.fromRGB(255, 0, 0)
    end)
    Pages[name] = P
    return P
end

-- 4. SECTION TOGGLE (BANANA HUB UI)
local function AddToggle(parent, text)
    local Section = Instance.new("Frame", parent)
    Section.Size = UDim2.new(1, -10, 0, 42)
    Section.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    Instance.new("UICorner", Section).CornerRadius = UDim.new(0, 6)
    
    local Label = Instance.new("TextLabel", Section)
    Label.Size = UDim2.new(1, -55, 1, 0)
    Label.Position = UDim2.new(0, 12, 0, 0)
    Label.Text = text
    Label.TextColor3 = Color3.fromRGB(255, 255, 255)
    Label.Font = Enum.Font.GothamSemibold
    Label.TextSize = 13
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.BackgroundTransparency = 1
    
    local Toggle = Instance.new("TextButton", Section)
    Toggle.Size = UDim2.new(0, 20, 0, 20)
    Toggle.Position = UDim2.new(1, -32, 0.5, -10)
    Toggle.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    Toggle.Text = ""
    Instance.new("UICorner", Toggle).CornerRadius = UDim.new(0, 4)
    Instance.new("UIStroke", Toggle).Color = Color3.fromRGB(255, 0, 0)

    local active = false
    Toggle.MouseButton1Click:Connect(function()
        active = not active
        Toggle.BackgroundColor3 = active and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(40, 40, 40)
    end)
end

-- 5. KRNL TOGGLE LOGIC
local open = false
LogoToggle.MouseButton1Click:Connect(function()
    if not draggingLogo then
        open = not open
        if open then
            Main.Visible = true
            Main.Size = UDim2.new(0, 0, 0, 0)
            TweenService:Create(Main, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                Size = UDim2.new(0, 560, 0, 320),
                BackgroundTransparency = 0.1
            }):Play()
        else
            local close = TweenService:Create(Main, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
                Size = UDim2.new(0, 0, 0, 0),
                BackgroundTransparency = 1
            })
            close:Play()
            close.Completed:Connect(function() if not open then Main.Visible = false end end)
        end
    end
end)

