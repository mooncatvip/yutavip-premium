-- 3. LOGIC TELEPORT AN TOÀN (SAFE-TP)
_G.REG_AutoChest = false

function REG_SafeTP(targetCFrame)
    local hrp = game.Players.LocalPlayer.Character.HumanoidRootPart
    local distance = (hrp.Position - targetCFrame.Position).Magnitude
    local speed = 350 -- Tốc độ lướt an toàn
    local tween = game:GetService("TweenService"):Create(hrp, TweenInfo.new(distance/speed, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
    tween:Play()
    tween.Completed:Wait()
end

-- 4. VÒNG LẶP NHẶT RƯƠNG
ToggleBtn.MouseButton1Click:Connect(function()
    _G.REG_AutoChest = not _G.REG_AutoChest
    if _G.REG_AutoChest then
        ToggleBtn.Text = "CHEST: ON"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
        
        task.spawn(function()
            while _G.REG_AutoChest do
                local found = false
                for _, v in pairs(game.Workspace:GetChildren()) do
                    if _G.REG_AutoChest == false then break end
                    if v.Name:find("Chest") and v:IsA("Part") then
                        REG_SafeTP(v.CFrame)
                        task.wait(0.3)
                        found = true
                    end
                end
                if not found then task.wait(2) end -- Đợi rương hồi
            end
        end)
    else
        ToggleBtn.Text = "CHEST: OFF"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
    end
end)

print("REG Hub đã sẵn sàng để vả thg em họ!")
