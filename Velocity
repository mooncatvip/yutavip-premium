task.spawn(function()
    while task.wait(5) do
        local Names = {}
        for _,v in pairs(game.Players:GetPlayers()) do
            table.insert(Names, v.Name .. " [Lvl " .. tostring(v.Data.Level.Value) .. "]")
        end
        PlayerList:Refresh(Names)
    end
end)

