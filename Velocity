-- 1. PLAYER INFO (LIVE DATA)
-- ==========================================
PlayerTab:CreateSection("Your Server Stats")
local MyName = PlayerTab:CreateLabel("Name: " .. game.Players.LocalPlayer.Name)
local MyLevel = PlayerTab:CreateLabel("Level: Loading...")
local MyMoney = PlayerTab:CreateLabel("Money: Loading...")
local MyFragments = PlayerTab:CreateLabel("Fragments: Loading...")
local MyBounty = PlayerTab:CreateLabel("Bounty: Loading...")
local ServerTime = PlayerTab:CreateLabel("Time in Server: 00:00:00")

task.spawn(function()
    local StartTime = tick()
    while task.wait(1) do
        pcall(function()
            local p = game.Players.LocalPlayer
            MyLevel:Set("Level: " .. tostring(p.Data.Level.Value))
            MyMoney:Set("Money: $" .. tostring(p.Data.Beli.Value))
            MyFragments:Set("Fragments: " .. tostring(p.Data.Fragments.Value))
            MyBounty:Set("Bounty: " .. tostring(p.leaderstats["Bounty/Honor"].Value))
            
            local Duration = tick() - StartTime
            local Hours = math.floor(Duration / 3600)
            local Mins = math.floor((Duration % 3600) / 60)
            local Secs = math.floor(Duration % 60)
            ServerTime:Set(string.format("Time in Server: %02d:%02d:%02d", Hours, Mins, Secs))
        end)
    end
end)

