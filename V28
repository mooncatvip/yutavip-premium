-- 4. HÀM TẠO TOGGLE (CHECKBOX ĐỎ)
local function AddToggle(name, parent)
    local F = Instance.new("Frame", parent)
    F.Size = UDim2.new(1, -10, 0, 40)
    F.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    Instance.new("UICorner", F)
    
    local L = Instance.new("TextLabel", F)
    L.Text = "  " .. name
    L.Size = UDim2.new(0.8, 0, 1, 0)
    L.TextColor3 = Color3.fromRGB(255, 255, 255)
    L.TextXAlignment = "Left"
    L.BackgroundTransparency = 1
    
    local Box = Instance.new("TextButton", F)
    Box.Text = ""
    Box.Size = UDim2.new(0, 22, 0, 22)
    Box.Position = UDim2.new(1, -35, 0.5, -11)
    Box.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    local BStroke = Instance.new("UIStroke", Box)
    BStroke.Color = Color3.fromRGB(255, 0, 0)
    Instance.new("UICorner", Box).CornerRadius = UDim.new(0, 4)

    local on = false
    Box.MouseButton1Click:Connect(function()
        on = not on
        Box.Text = on and "✓" or ""
        Box.TextColor3 = Color3.fromRGB(255, 0, 0)
        -- Chèn logic từ Hdanh Hub tại đây
    end)
end

