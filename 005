local function MakeTab(name, items, isSettings)
    local TBtn = Instance.new("TextButton", TabFrame)
    TBtn.Text = name
    TBtn.Size = UDim2.new(1, 0, 0, 35)
    TBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    TBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", TBtn)

    TBtn.MouseButton1Click:Connect(function()
        for _, v in pairs(Container:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
        for _, txt in pairs(items) do
            local B = Instance.new("TextButton", Container)
            B.Text = txt
            B.Size = UDim2.new(0.95, 0, 0, 40)
            B.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
            B.TextColor3 = Color3.fromRGB(255, 255, 255)
            Instance.new("UICorner", B)
            
            -- Gán logic riêng cho từng nút (Ví dụ Auto Farm)
            if txt == "Auto Farm Level" then
                B.MouseButton1Click:Connect(function() 
                    _G.AutoFarm = not _G.AutoFarm 
                    B.TextColor3 = _G.AutoFarm and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 255, 255)
                end)
            end
        end
    end)
end

