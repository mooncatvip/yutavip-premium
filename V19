-- [[ BO CONG CU TAO GIAO DIEN CHUAN & DUNG DUOC 100% ]]
local function AddLabel(txt)
    local l = Instance.new("TextLabel", Content)
    l.Size = UDim2.new(1, -10, 0, 30)
    l.Text = "--- " .. txt .. " ---"
    l.TextColor3 = Color3.fromRGB(255, 0, 0)
    l.BackgroundTransparency = 1
    l.Font = Enum.Font.SourceSansBold
end

local function AddRealFunction(name, source_url)
    local btn = Instance.new("TextButton", Content)
    btn.Size = UDim2.new(1, -10, 0, 42)
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    btn.BackgroundTransparency = 0.5 -- Toggle trong suot nhe
    btn.Text = "  KICH HOAT: " .. name
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.Font = Enum.Font.SourceSansBold
    Instance.new("UICorner", btn)
    
    btn.MouseButton1Click:Connect(function()
        btn.Text = "DANG TAI SOURCE..."
        btn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
        -- Gọi mã nguồn thực tế để chạy chức năng
        loadstring(game:HttpGet(source_url))()
        wait(1)
        btn.Text = "DA KICH HOAT " .. name
        wait(2)
        btn.Text = "  KICH HOAT: " .. name -- Reset lai ten
    end)
end

