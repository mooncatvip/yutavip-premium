-- Hiệu ứng khi bấm vào
AutoFarmBtn.MouseButton1Click:Connect(function()
    print("Yuta đã kích hoạt Auto Farm!")
    -- Chỗ này sau này mình sẽ nhồi code Auto Farm vào đây
end)
