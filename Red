Tabs.Settings:AddToggle("FullBright", {Title = "Full Bright (Sáng vl)", Default = false, Callback = function(v)
    game:GetService("Lighting").Ambient = v and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(0, 0, 0)
end})
Tabs.Settings:AddButton({Title = "ULTRA FIX LAG (POCO)", Callback = function()
    for i,v in pairs(game:GetDescendants()) do
        if v:IsA("BasePart") then v.Material = "Plastic" end
        if v:IsA("Decal") then v:Destroy() end
    end
end})

