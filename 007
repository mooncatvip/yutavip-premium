-- --- HÀM TẠO Ô TÍCH (CHECKBOX) CHUẨN ---
local function CreateCheckbox(parent, text, default, callback)
    local Frame = Instance.new("Frame", parent)
    Frame.Size = UDim2.new(0.9, 0, 0, 35)
    Frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Instance.new("UICorner", Frame)

    local Lbl = Instance.new("TextLabel", Frame)
    Lbl.Text = "  " .. text Lbl.Size = UDim2.new(0.7, 0, 1, 0)
    Lbl.TextColor3 = Color3.fromRGB(255, 255, 255) LLbl.BackgroundTransparency = 1 LLbl.TextXAlignment = "Left"

    local Box = Instance.new("TextButton", Frame)
    Box.Size = UDim2.new(0, 22, 0, 22) Box.Position = UDim2.new(1, -32, 0.5, -11)
    Box.BackgroundColor3 = default and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(50, 50, 50)
    Box.Text = default and "✓" or "" Box.TextColor3 = Color3.fromRGB(255, 255, 255) Instance.new("UICorner", Box)

    local state = default
    Box.MouseButton1Click:Connect(function() 
        state = not state Box.Text = state and "✓" or "" 
        Box.BackgroundColor3 = state and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(50, 50, 50) 
        callback(state) 
    end)
end

-- --- THIẾT LẬP CÁC TAB THEO SƠ ĐỒ CỦA ÔNG ---
local function MakeTab(name, items)
    local TBtn = Instance.new("TextButton", TabFrame)
    TBtn.Text = name TBtn.Size = UDim2.new(1, 0, 0, 35)
    TBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 25) TBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", TBtn)
    TBtn.MouseButton1Click:Connect(function()
        for _, v in pairs(Container:GetChildren()) do if not v:IsA("UIListLayout") then v:Destroy() end end
        SectionTitle.Text = "YUTA HUB - " .. name:upper()
        for _, text in pairs(items) do
            CreateCheckbox(Container, text, false, function(s)
                if text == "Auto Farm Level" then _G.AutoFarm = s end
                print(text .. " state: " .. tostring(s))
            end)
        end
    end)
end

