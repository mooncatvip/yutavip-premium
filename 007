-- --- HÀM TÌM QUÁI LEVEL (CHỐNG ĐÁNH LUNG TUNG) ---
local function GetMonster()
    local myLv = LPlayer.Data.Level.Value
    local tName = (myLv >= 2700 and "Living Zombie") or (myLv >= 2500 and "Warrior") or "Monster"
    for _, v in pairs(game:GetService("Workspace").Enemies:GetChildren()) do
        if v.Name:find(tName) and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then return v end
    end
    return nil
end

