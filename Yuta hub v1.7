Tabs.Settings:AddSection("24/7 AFK Optimization")

Tabs.Settings:AddToggle("AlwaysDay", {Title = "Always Day", Default = true})
:OnChanged(function(v)
    _G.AlwaysDay = v
    task.spawn(function()
        while _G.AlwaysDay do
            game.Lighting.ClockTime = 12
            task.wait(5)
        end
    end)
end)

Tabs.Settings:AddButton({
    Title = "Ultra Fix Lag (24/7 Mode)",
    Description = "Remove Textures, Fog, Clouds for low-end devices",
    Callback = function()
        game.Lighting.FogEnd = 9e9
        game.Lighting.GlobalShadows = false
        for i,v in pairs(game:GetDescendants()) do
            if v:IsA("BasePart") or v:IsA("MeshPart") then
                v.Material = "Plastic"
                v.Reflectance = 0
            elseif v:IsA("Decal") or v:IsA("Texture") or v:IsA("Clouds") or v:IsA("Atmosphere") then
                v:Destroy()
            end
        end
        settings().Rendering.QualityLevel = 1
        Fluent:Notify({Title = "YUTA HUB", Content = "Optimization Finished!"})
    end
})

