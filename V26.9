-- 4. TẠO CÁC TAB (XÁO TRỘN 100%)
local function AddTab(name, pos)
    local Tab = Instance.new("TextButton", Sidebar)
    Tab.Size = UDim2.new(1, -14, 0, 32)
    Tab.Position = UDim2.new(0, 7, 0, (pos-1)*36 + 40)
    Tab.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    Tab.Text = "  " .. name
    Tab.TextColor3 = Color3.fromRGB(200, 200, 200)
    Tab.Font = Enum.Font.SourceSansBold
    Tab.TextSize = 14
    Tab.TextXAlignment = Enum.TextXAlignment.Left
    Instance.new("UICorner", Tab).CornerRadius = UDim.new(0, 5)
    
    -- Hiệu ứng hover giả khi bấm
    Tab.MouseButton1Click:Connect(function()
        for _,v in pairs(Sidebar:GetChildren()) do
            if v:IsA("TextButton") then v.TextColor3 = Color3.fromRGB(200, 200, 200) end
        end
        Tab.TextColor3 = Color3.fromRGB(255, 0, 0)
    end)
end

