-- --- [3. HÀM TẠO NỘI DUNG TỪNG TAB] ---
local function CreateToggle(txt, callback)
    local F = Instance.new("Frame", Content)
    F.Size = UDim2.new(0.95, 0, 0, 45)
    F.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    Instance.new("UICorner", F)
    local L = Instance.new("TextLabel", F)
    L.Text = "  " .. txt L.Size = UDim2.new(0.7, 0, 1, 0)
    L.TextColor3 = Color3.fromRGB(255, 255, 255) L.BackgroundTransparency = 1 L.TextXAlignment = "Left"
    local B = Instance.new("TextButton", F)
    B.Size = UDim2.new(0, 28, 0, 28) B.Position = UDim2.new(1, -40, 0.5, -14)
    B.BackgroundColor3 = Color3.fromRGB(50, 50, 50) B.Text = "" Instance.new("UICorner", B)
    local s = false
    B.MouseButton1Click:Connect(function() 
        s = not s B.Text = s and "✓" or "" 
        B.BackgroundColor3 = s and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(50, 50, 50) 
        callback(s) 
    end)
end

local function MakeTab(name)
    local T = Instance.new("TextButton", TabFrame)
    T.Text = name T.Size = UDim2.new(1, 0, 0, 38)
    T.BackgroundColor3 = Color3.fromRGB(30, 30, 30) T.TextColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", T)
    T.MouseButton1Click:Connect(function()
        for _, v in pairs(Content:GetChildren()) do if not v:IsA("UIListLayout") then v:Destroy() end end
        if name == "Farm" then
            CreateToggle("Auto Farm Level", function(s) _G.AutoFarm = s end)
            CreateToggle("Auto Farm Bone", function(s) _G.AutoBone = s end)
        elseif name == "Shop" then
            local shopItems = {"Saber", "Bispento", "Random Fruit", "Black Leg"}
            for _, i in pairs(shopItems) do
                local Btn = Instance.new("TextButton", Content)
                Btn.Text = "Mua " .. i Btn.Size = UDim2.new(0.95, 0, 0, 40)
                Btn.MouseButton1Click:Connect(function() Remote:InvokeServer("BuyItem", i) end)
            end
        elseif name == "Settings" then
            local speed = Instance.new("TextBox", Content)
            speed.PlaceholderText = "Nhập Speed..." speed.Size = UDim2.new(0.95, 0, 0, 40)
            speed.FocusLost:Connect(function() _G.WalkSpeed = tonumber(speed.Text) or 16 end)
            CreateToggle("Tele Admin", function(s) if s then LPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(0, 5000, 0) end end)
        end
    end)
end

