local Sidebar = Instance.new("Frame", MainContainer)
Sidebar.Position = UDim2.new(0, 8, 0, 50)
Sidebar.Size = UDim2.new(0, 85, 1, -60)
Sidebar.BackgroundTransparency = 1
Instance.new("UIListLayout", Sidebar).Padding = UDim.new(0, 5)

local PageContainer = Instance.new("Frame", MainContainer)
PageContainer.Position = UDim2.new(0, 100, 0, 50)
PageContainer.Size = UDim2.new(1, -110, 1, -60)
PageContainer.BackgroundTransparency = 1

local Pages = {}
local function AddTab(name)
    local P = Instance.new("ScrollingFrame", PageContainer)
    P.Name = name
    P.Size = UDim2.new(1, 0, 1, 0)
    P.Visible = false
    P.BackgroundTransparency = 1
    P.ScrollBarThickness = 0
    Instance.new("UIListLayout", P).Padding = UDim.new(0, 5)
    
    local TabBtn = Instance.new("TextButton", Sidebar)
    TabBtn.Size = UDim2.new(1, 0, 0, 32)
    TabBtn.Text = name
    TabBtn.TextColor3 = Color3.fromRGB(150, 150, 150)
    TabBtn.Font = Enum.Font.SourceSansBold
    TabBtn.BackgroundTransparency = 1

    TabBtn.MouseButton1Click:Connect(function()
        for _, v in pairs(Pages) do v.Visible = false end
        P.Visible = true
        for _, t in pairs(Sidebar:GetChildren()) do
            if t:IsA("TextButton") then t.TextColor3 = Color3.fromRGB(150, 150, 150) end
        end
        TabBtn.TextColor3 = Color3.fromRGB(255, 0, 0)
    end)
    Pages[name] = P
    return P
end

-- SETUP MUSIC & DRAGON JOURNEY
local DragonTab = AddTab("Dragon")
local MusicTab = AddTab("Music")

local function AddToggle(parent, text)
    local Frame = Instance.new("TextButton", parent)
    Frame.Size = UDim2.new(1, 0, 0, 38)
    Frame.BackgroundTransparency = 1
    Frame.Text = ""
    local Label = Instance.new("TextLabel", Frame)
    Label.Size = UDim2.new(1, -25, 1, 0)
    Label.Text = text
    Label.TextColor3 = Color3.fromRGB(255, 255, 255)
    Label.BackgroundTransparency = 1
    local Box = Instance.new("Frame", Frame)
    Box.Size = UDim2.new(0, 18, 0, 18)
    Box.Position = UDim2.new(1, -22, 0.5, -9)
    Box.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Instance.new("UIStroke", Box).Color = Color3.fromRGB(255, 0, 0)
    Instance.new("UICorner", Box).CornerRadius = UDim.new(0, 5)
    local state = false
    Frame.MouseButton1Click:Connect(function()
        state = not state
        Box.BackgroundColor3 = state and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(30, 30, 30)
    end)
end

AddToggle(DragonTab, "Auto Mirage")
AddToggle(MusicTab, "Super Hero 2018") -- Bài đề cử của YUTA

DragonTab.Visible = true
