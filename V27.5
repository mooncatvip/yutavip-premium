-- 3. HIỆU ỨNG CHUYỂN ĐỘNG KIỂU KRNL (TWEEN)
local isOpen = false
local function ToggleMenu()
    isOpen = not isOpen
    
    if isOpen then
        MainContainer.Visible = true
        MainContainer.Size = UDim2.new(0, 0, 0, 0) -- Bắt đầu từ 0
        MainContainer.BackgroundTransparency = 1
        
        -- Phóng to và hiện rõ dần
        TweenService:Create(MainContainer, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 280, 0, 480),
            BackgroundTransparency = 0.1
        }):Play()
    else
        -- Thu nhỏ và biến mất
        local closeTween = TweenService:Create(MainContainer, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 0, 0, 0),
            BackgroundTransparency = 1
        })
        closeTween:Play()
        closeTween.Completed:Connect(function()
            if not isOpen then MainContainer.Visible = false end
        end)
    end
end

LogoToggle.MouseButton1Click:Connect(ToggleMenu)

-- 4. NỘI DUNG MENU (GIỮ NGUYÊN COLLAB CỦA CHÚNG TA)
