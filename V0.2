    warn("YUTA DETECTED! AUTO-LOGIN...")
    UnlockHub()
end

-- Xử lý nút Verify
VerifyBtn.MouseButton1Click:Connect(function()
    local key = Input.Text
    if key == "YutaHub_Final_Infinite" then
        VerifyBtn.Text = "CHÀO CHỦ NHÂN QUAY LẠI! (INFINITE)"
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
        task.wait(1)
        UnlockHub()
    elseif string.match(key, "^YutaHub_Final_6h_") then
        VerifyBtn.Text = "XÁC THỰC THÀNH CÔNG (6H)"
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
        task.wait(1)
        UnlockHub()
    else
        VerifyBtn.Text = "KEY HẾT HẠN HOẶC BỊ LỖI!"
        task.wait(1.5)
        VerifyBtn.Text = "VERIFY KEY"
    end
end)
