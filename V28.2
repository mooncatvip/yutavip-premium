local function AddSection(title)
    local Sec = Instance.new("Frame", Container)
    Sec.Size = UDim2.new(1, -10, 0, 30)
    Sec.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    Sec.AutomaticSize = "Y"
    Instance.new("UICorner", Sec).CornerRadius = UDim.new(0, 6)
    
    local Head = Instance.new("TextLabel", Sec)
    Head.Size = UDim2.new(1, 0, 0, 28)
    Head.Text = title
    Head.TextColor3 = Color3.fromRGB(255, 200, 0)
    Head.Font = "GothamBold"
    Head.TextSize = 13
    Head.BackgroundTransparency = 1
    
    local List = Instance.new("UIListLayout", Sec)
    List.Padding = UDim.new(0, 6)
    List.HorizontalAlignment = "Center"
    return Sec
end

-- 6. HÀM BẬT/TẮT KIỂU KRNL (FIX)
local isOpen = false
Logo.MouseButton1Click:Connect(function()
    isOpen = not isOpen
    if isOpen then
        Main.Visible = true
        Main.Size = UDim2.new(0, 0, 0, 0)
        TweenService:Create(Main, TweenInfo.new(0.4, Enum.EasingStyle.Back), {Size = UDim2.new(0, 580, 0, 340)}):Play()
    else
        local tw = TweenService:Create(Main, TweenInfo.new(0.3), {Size = UDim2.new(0, 0, 0, 0)})
        tw:Play()
        tw.Completed:Connect(function() if not isOpen then Main.Visible = false end end)
    end
end)

